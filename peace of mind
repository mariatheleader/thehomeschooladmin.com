        <h2>You chose this for your children. Let’s make it feel lighter.</h2>
        <p>Send: <strong>“Maria, I’m ready for support.”</strong></p>
        <span class="cta">Apply through the link</span>
      </div>
      <div class="brand">The Homeschool Admin™</div>
    </section>
  </main>

  <nav class="nav" aria-label="Presentation navigation">
    <button onclick="prevSlide()" aria-label="Previous slide">←</button>
    <span class="counter"><span id="current">1</span>/<span id="total">13</span></span>
    <button onclick="nextSlide()" aria-label="Next slide">→</button>
  </nav>

  <script>
    const slides = Array.from(document.querySelectorAll('.slide'));
    let index = 0;
    const current = document.getElementById('current');
    const total = document.getElementById('total');
    total.textContent = slides.length;

    function showSlide(i) {
      slides[index].classList.remove('active');
      index = (i + slides.length) % slides.length;
      slides[index].classList.add('active');
      current.textContent = index + 1;
    }

    function nextSlide() { showSlide(index + 1); }
    function prevSlide() { showSlide(index - 1); }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowRight' || event.key === ' ') nextSlide();
      if (event.key === 'ArrowLeft') prevSlide();
    });
  </script>
</body>
</html>
