<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Homeschooling Without the Overwhelm | The Homeschool Admin</title>
  <style>
    :root {
      --cream: #f7efe4;
      --warm: #e7c7a6;
      --tan: #b9825a;
      --clay: #9b5f3d;
      --espresso: #2d211a;
      --ink: #1f1a16;
      --sage: #6f7b5f;
      --white: #fffaf3;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Georgia, 'Times New Roman', serif;
      color: var(--ink);
      background: var(--espresso);
      overflow: hidden;
    }

    .deck {
      width: 100vw;
      height: 100vh;
      position: relative;
    }

    .slide {
      display: none;
      width: 100vw;
      height: 100vh;
      position: absolute;
      inset: 0;
      background: var(--cream);
      overflow: hidden;
    }

    .slide.active { display: grid; }

    .photo-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }

    .scrim {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(31,26,22,.82), rgba(31,26,22,.36), rgba(31,26,22,.05));
      z-index: 1;
    }

    .scrim-light {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(247,239,228,.95), rgba(247,239,228,.74), rgba(247,239,228,.12));
      z-index: 1;
    }

    .content {
      position: relative;
      z-index: 2;
      padding: 7vh 7vw;
      max-width: 880px;
      align-self: center;
    }

    .content.wide { max-width: 1120px; }
    .content.right { margin-left: auto; }
    .content.center { margin: auto; text-align: center; }

    .eyebrow {
      font-family: Arial, sans-serif;
      font-size: 15px;
      line-height: 1.2;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--clay);
      margin-bottom: 22px;
      font-weight: 700;
    }

    .dark .eyebrow { color: var(--warm); }

    h1, h2 {
      margin: 0;
      line-height: .95;
      letter-spacing: -0.04em;
      font-weight: 500;
    }

    h1 { font-size: clamp(58px, 8vw, 116px); }
    h2 { font-size: clamp(44px, 6.5vw, 86px); }

    p {
      font-family: Arial, sans-serif;
      font-size: clamp(20px, 2.1vw, 30px);
      line-height: 1.35;
      max-width: 760px;
    }

    .dark { color: var(--white); }

    .big-line {
      font-size: clamp(34px, 5vw, 68px);
      line-height: 1.03;
      letter-spacing: -0.04em;
      max-width: 920px;
      margin: 0;
    }

    .bullets {
      font-family: Arial, sans-serif;
      font-size: clamp(22px, 2.4vw, 34px);
      line-height: 1.45;
      margin-top: 28px;
      padding-left: 0;
      list-style: none;
    }

    .bullets li { margin: 15px 0; }
    .bullets li::before { content: '→ '; color: var(--clay); font-weight: 800; }
    .dark .bullets li::before { color: var(--warm); }

    .split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      height: 100%;
    }

    .split .text-side {
      padding: 7vh 6vw;
      display: flex;
      flex-direction: column;
      justify-content: center;
      z-index: 2;
    }

    .split .image-side {
      position: relative;
      overflow: hidden;
    }

    .split img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .quote {
      font-size: clamp(34px, 4.5vw, 64px);
      line-height: 1.08;
      letter-spacing: -0.04em;
      margin: 0;
    }

    .small {
      font-size: clamp(16px, 1.6vw, 22px);
      line-height: 1.4;
    }

    .formula {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 26px;
      align-items: center;
      margin-top: 42px;
      font-family: Arial, sans-serif;
    }

    .formula-box {
      border: 2px solid var(--clay);
      padding: 28px;
      min-height: 170px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: rgba(255,250,243,.46);
    }

    .formula-box strong {
      display: block;
      font-size: clamp(46px, 6vw, 80px);
      font-family: Georgia, 'Times New Roman', serif;
      font-weight: 500;
      margin-bottom: 8px;
    }

    .plus { font-size: 56px; color: var(--clay); }

    .system-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-top: 42px;
    }

    .step {
      border-top: 3px solid var(--clay);
      padding-top: 18px;
      font-family: Arial, sans-serif;
      font-size: clamp(18px, 1.6vw, 24px);
      line-height: 1.25;
    }

    .step span {
      display: block;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 46px;
      color: var(--clay);
      margin-bottom: 8px;
    }

    .cta {
      display: inline-block;
      margin-top: 32px;
      padding: 18px 28px;
      border: 2px solid var(--espresso);
      font-family: Arial, sans-serif;
      font-weight: 800;
      letter-spacing: .04em;
      text-transform: uppercase;
      background: var(--white);
    }

    .dark .cta {
      border-color: var(--white);
      color: var(--espresso);
      background: var(--white);
    }

    .brand {
      position: absolute;
      z-index: 4;
      left: 28px;
      bottom: 22px;
      font-family: Arial, sans-serif;
      font-size: 13px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: rgba(255,250,243,.8);
    }

    .light-brand { color: rgba(31,26,22,.55); }

    .nav {
      position: absolute;
      z-index: 10;
      right: 26px;
      bottom: 20px;
      display: flex;
      gap: 10px;
      align-items: center;
      font-family: Arial, sans-serif;
    }

    button {
      border: 0;
      background: rgba(255,250,243,.9);
      color: var(--espresso);
      padding: 10px 14px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 700;
      box-shadow: 0 8px 25px rgba(0,0,0,.18);
    }

    .counter {
      color: var(--white);
      background: rgba(31,26,22,.55);
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 13px;
    }

    @media (max-width: 850px) {
      body { overflow: auto; }
      .deck, .slide { height: auto; min-height: 100vh; }
      .slide { position: relative; }
      .split { grid-template-columns: 1fr; }
      .split .image-side { min-height: 42vh; order: -1; }
      .formula, .system-steps { grid-template-columns: 1fr; }
      .plus { display: none; }
      .content, .split .text-side { padding: 9vh 7vw 12vh; }
      .nav { position: fixed; }
    }

    @media print {
      body { overflow: visible; background: white; }
      .deck, .slide { width: 100%; height: 100vh; page-break-after: always; position: relative; display: grid !important; }
      .nav { display: none; }
    }
  </style>
</head>
<body>
  <main class="deck" aria-label="Homeschooling Without the Overwhelm presentation">
    <section class="slide active dark">
